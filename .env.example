# Copy to .env and fill in values
# NEVER commit .env to git

# Zhipu AI (Z.AI): default LLM for transpiler + judge (GLM-5)
ZHIPUAI_API_KEY=
#
# Optional transpiler overrides (defaults shown):
# PSRH_TRANSPILER_MODEL=anthropic/glm-5
# PSRH_TRANSPILER_API_KEY_ENV=ZHIPUAI_API_KEY
# PSRH_TRANSPILER_API_BASE=https://api.z.ai/api/anthropic
# PSRH_TRANSPILER_PROVIDER=anthropic

# Tinker API (optional; alternative to local TRL training)
TINKER_API_KEY=

# Additional providers (optional, for multi-model evaluation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Weights & Biases (optional; required for online sweeps)
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=ppl-synthesis-reward-hacking
