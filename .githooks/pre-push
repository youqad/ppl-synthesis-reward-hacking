#!/usr/bin/env bash
# pre-push: verify pixi can parse pyproject.toml before pushing
# prevents CI failures from unparseable dependency specifiers

if command -v pixi &>/dev/null; then
  if ! pixi info --manifest-path pyproject.toml &>/dev/null 2>&1; then
    echo "pre-push: pixi cannot parse pyproject.toml"
    echo "run 'pixi info' to see the error"
    exit 1
  fi
fi
